VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=


VITE_SITE_DATA_API_BASE=http://localhost:5174


VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

VITE_CLOUDINARY_FOLDER=maneesh-events

## Firebase (optional) - store uploaded Cloudinary CDN URLs
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# If you want to use Firebase Realtime Database (instead of Firestore)
VITE_FIREBASE_DATABASE_URL=

# Enable shared site data via Firebase (optional)
VITE_FIREBASE_SITE_DATA_ENABLED=false
VITE_FIREBASE_SITE_DATA_PATH=siteData/v1

## Server-only env vars (used by `npm run server`)
PORT=5174
SITE_DATA_FILE=./server/data/site-data.json
ADMIN_USERNAME=
ADMIN_PASSWORD=
CORS_ORIGIN=http://localhost:5173
